# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=123456
REDIS_DB=0

# MinerU 云端 API（https://mineru.net/apiManage 申请 Token）
MINERU_TOKEN=your_mineru_token_here
MINERU_MODEL_VERSION=vlm

# Elasticsearch
ES_HOST=http://localhost:9200

# ChromaDB 本地持久化目录
CHROMA_PERSIST_DIR=D:/Code/AI-Projects/my-intelligence/data/chroma

# Ollama（Embedding 使用 OpenAI 兼容协议）
OLLAMA_BASE_URL=http://localhost:11434/v1
EMBEDDING_MODEL=nomic-embed-text
CHAT_MODEL=qwen3.5:9b

# AI 客户端（Anthropic 兼容协议，默认指向 Ollama）
AI_API_BASE_URL=http://localhost:11434/v1
AI_API_KEY=ollama
AI_MODEL=
AI_MAX_TOKENS=4096
AI_TEMPERATURE=0.3

# 文件存储根路径（与 Java 端 app.file.root-path 一致）
FILE_ROOT_PATH=D:/Code/AI-Projects/my-intelligence/data

# 轮询间隔（秒）
POLL_INTERVAL=60

# Flask
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
